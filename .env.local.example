# ─── Database ────────────────────────────────────────────────────────────────
# Neon Postgres connection string (Vercel Marketplace → Neon → Connect)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/account
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/account
# Set your admin user ID from Clerk dashboard
ADMIN_CLERK_USER_ID=user_...

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe Dashboard → Webhooks → Add endpoint → copy signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Shippo (Shipping Labels) ─────────────────────────────────────────────────
# Shippo Dashboard → API → Token
SHIPPO_API_KEY=shippo_test_...

# ─── Resend (Transactional Email) ────────────────────────────────────────────
# Resend Dashboard → API Keys
RESEND_API_KEY=re_...
# The ONE sender identity for every transactional customer email — deliberately
# not split per email type, see lib/resend.ts. Until pepscorelab.com is
# verified as a sending domain in Resend, leave this unset — falls back to
# Resend's own onboarding@resend.dev sandbox address, which is safe to send
# from with no domain verification. Once verified, set this to the display
# name + address below; no code change needed.
RESEND_FROM_EMAIL="Pepscore Orders <orders@pepscorelab.com>"
# Default Reply-To when a send site doesn't pick a more specific mailbox
# (see BILLING_EMAIL/CONTACT_EMAIL below for the context-specific ones).
# Defaults to SUPPORT_EMAIL if unset.
RESEND_REPLY_TO_EMAIL=support@pepscorelab.com

# ─── pepscorelab.com mailboxes ────────────────────────────────────────────────
# Five real Google Workspace mailboxes, never hardcoded — see lib/resend.ts
# for which email each is used as Reply-To on. None require Resend domain
# verification (display text / Reply-To only, never the SMTP sender) — safe
# to set now regardless of RESEND_FROM_EMAIL's status above.
ADMIN_EMAIL=admin@pepscorelab.com
BILLING_EMAIL=billing@pepscorelab.com
CONTACT_EMAIL=contact@pepscorelab.com
ORDERS_EMAIL=orders@pepscorelab.com
SUPPORT_EMAIL=support@pepscorelab.com

# ─── Twilio (SMS delivery of intake links) ───────────────────────────────────
# Optional — until all three are set, the "Send via SMS" button on the intake
# link admin UI stays disabled and falls back to Email/Copy Link; no code
# change is needed to activate it, it just starts working once these are set
# and the app is redeployed. Twilio Console → Account → API keys & tokens;
# phone number from Twilio Console → Phone Numbers (must be SMS-capable).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Cron ────────────────────────────────────────────────────────────────────
# Random secret shared with the Vercel Cron trigger for /api/cron/* routes —
# Vercel sends it as `Authorization: Bearer <value>` on scheduled invocations.
CRON_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# The Shippo return/ship-from address is configured in the app itself, not
# here — see Settings → Fulfillment (FulfillmentSettings.returnAddress),
# shared by both storefront Order labels and Invoice fulfillment labels.
