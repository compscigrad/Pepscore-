# ─── Database ────────────────────────────────────────────────────────────────
# Neon Postgres connection string (Vercel Marketplace → Neon → Connect)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/account
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/account
# Set your admin user ID from Clerk dashboard
ADMIN_CLERK_USER_ID=user_...

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe Dashboard → Webhooks → Add endpoint → copy signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Shippo (Shipping Labels) ─────────────────────────────────────────────────
# Shippo Dashboard → API → Token
SHIPPO_API_KEY=shippo_test_...

# ─── Resend (Transactional Email) ────────────────────────────────────────────
# Resend Dashboard → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=orders@pepscore.com

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Pepscore warehouse ship-from address (used for Shippo label creation)
SHIP_FROM_NAME="Pepscore Research"
SHIP_FROM_STREET="123 Lab Way"
SHIP_FROM_CITY="Miami"
SHIP_FROM_STATE="FL"
SHIP_FROM_ZIP="33101"
SHIP_FROM_COUNTRY="US"
SHIP_FROM_PHONE="+13055550000"
