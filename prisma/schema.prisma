// Pepscore database schema
// Run: npx prisma db push   (to sync with Neon)
//      npx prisma generate  (to regenerate the client)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  phone     String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders         Order[]
  complianceLogs ComplianceAcknowledgment[]

  @@index([email])
}

enum Role {
  CUSTOMER
  ADMIN
}

// ─── Products ────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String
  size        String
  price       Float
  bulkPrice5  Float?
  bulkPrice10 Float?
  description String
  imageUrl    String
  badge       String?
  inStock     Boolean  @default(true)
  costOfGoods Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems   OrderItem[]
  invoiceItems InvoiceItem[]

  @@index([slug])
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id                    String            @id @default(cuid())
  orderNumber           String            @unique
  userId                String?
  user                  User?             @relation(fields: [userId], references: [id])
  customerEmail         String
  customerName          String
  shippingAddress       Json
  status                OrderStatus       @default(PENDING)
  fulfillmentStatus     FulfillmentStatus @default(UNFULFILLED)
  stripeSessionId       String?           @unique
  stripePaymentIntentId String?
  subtotal              Float
  shippingCost          Float             @default(0)
  stripeFee             Float             @default(0)
  tax                   Float             @default(0)
  total                 Float
  notes                 String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  items          OrderItem[]
  invoice        Invoice?
  shippingLabel  ShippingLabel?
  payments       Payment[]
  complianceLogs ComplianceAcknowledgment[]

  @@index([customerEmail])
  @@index([stripeSessionId])
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  FULFILLED
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  name        String
  size        String
  quantity    Int
  unitPrice   Float
  costOfGoods Float   @default(0)
  total       Float
}

// ─── Invoices ────────────────────────────────────────────────────────────────
// The invoice module stands on its own: orderId is optional so an invoice can
// represent a Stripe-driven storefront sale (linked) OR a fully manual,
// off-platform sale (unlinked) — e.g. a DM/cash sale with no Order record.
// Customer/shipping fields are duplicated onto Invoice rather than requiring
// a User/Order so a manual invoice is self-contained and never blocked on
// those records existing.

model Invoice {
  id              String  @id @default(cuid())
  invoiceNumber   String  @unique
  orderId         String? @unique
  order           Order?  @relation(fields: [orderId], references: [id])
  stripeInvoiceId String?

  // Customer (snapshotted at invoice time, independent of User/Order)
  customerName    String
  customerCompany String?
  customerEmail   String?
  customerPhone   String?
  billingAddress  Json?
  shippingAddress Json?
  internalNotes   String?
  publicNotes     String?

  // Shipping / fulfillment
  carrier        ShippingCarrier?
  trackingNumber String?
  shippingCost   Float            @default(0)
  shipDate       DateTime?
  deliveryDate   DateTime?
  deliveredDate  DateTime?
  deliveryStatus DeliveryStatus   @default(PREPARING)

  // Financials — stored (not just derived) so history survives later price/promo edits
  subtotal      Float @default(0)
  discountTotal Float @default(0)
  total         Float @default(0)
  amountPaid    Float @default(0)
  balanceDue    Float @default(0)

  status     InvoiceStatus @default(DRAFT)
  issuedAt   DateTime      @default(now())
  paidAt     DateTime?
  archivedAt DateTime?

  // Generated on-demand (see lib/invoice/pdf); columns reserved for when
  // persistent blob storage is added — see docs/Decisions.md
  pdfMasterUrl    String?
  pdfRecipientUrl String?

  items     InvoiceItem[]
  discounts InvoiceDiscount[]
  payments  InvoicePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerEmail])
  @@index([customerName])
  @@index([status])
  @@index([createdAt])
}

enum InvoiceStatus {
  DRAFT
  PENDING
  APPROVED
  ISSUED
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
  VOID
}

enum ShippingCarrier {
  USPS
  UPS
  FEDEX
  DHL
  PICKUP
  HAND_DELIVERY
  COURIER
  OTHER
}

enum DeliveryStatus {
  PREPARING
  PACKED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
  LOST
  DAMAGED
}

model InvoiceItem {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id])
  name         String
  description  String?
  quantity     Int      @default(1)
  unitPrice    Float
  lineDiscount Float    @default(0)
  total        Float
  sortOrder    Int      @default(0)

  @@index([invoiceId])
}

// Reusable discount templates (e.g. "FF", "Gift", "Holiday Sale") so the
// same promo can be applied across many invoices without retyping terms.
model Promotion {
  id          String        @id @default(cuid())
  name        String
  description String?
  type        PromotionType
  amount      Float
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  invoiceDiscounts InvoiceDiscount[]
}

enum PromotionType {
  FIXED
  PERCENTAGE
}

// Applied-discount snapshot. Stores its own label/type/amount independent of
// Promotion so editing or deleting a Promotion later never rewrites history
// on invoices that already used it.
model InvoiceDiscount {
  id            String        @id @default(cuid())
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  promotionId   String?
  promotion     Promotion?    @relation(fields: [promotionId], references: [id])
  label         String
  type          PromotionType
  amount        Float
  appliedAmount Float

  @@index([invoiceId])
}

model InvoicePayment {
  id              String        @id @default(cuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount          Float
  method          PaymentMethod
  referenceNumber String?
  paidAt          DateTime      @default(now())
  notes           String?

  @@index([invoiceId])
}

enum PaymentMethod {
  CASH
  COD
  CREDIT_CARD
  APPLE_PAY
  STRIPE
  SQUARE
  CASH_APP
  VENMO
  ZELLE
  ACH
  WIRE
  CHECK
  CRYPTO
  OTHER
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  orderId               String
  order                 Order         @relation(fields: [orderId], references: [id])
  stripePaymentIntentId String        @unique
  amount                Float
  currency              String        @default("usd")
  status                PaymentStatus
  stripeFee             Float         @default(0)
  netAmount             Float         @default(0)
  createdAt             DateTime      @default(now())

  @@index([orderId])
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ─── Shipping ────────────────────────────────────────────────────────────────

model ShippingLabel {
  id             String   @id @default(cuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  carrier        String
  service        String
  trackingNumber String
  labelUrl       String
  shippoLabelId  String?
  cost           Float
  createdAt      DateTime @default(now())
}

// ─── Compliance ──────────────────────────────────────────────────────────────

model ComplianceAcknowledgment {
  id        String   @id @default(cuid())
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  sessionId String?
  ipAddress String?
  userAgent String?
  // Full RUO text the customer agreed to
  ruoText   String
  agreedAt  DateTime @default(now())
}

// ─── Accounting ──────────────────────────────────────────────────────────────

model Expense {
  id          String      @id @default(cuid())
  type        ExpenseType
  amount      Float
  description String?
  orderId     String?
  date        DateTime    @default(now())
  createdAt   DateTime    @default(now())

  @@index([type])
  @@index([date])
}

enum ExpenseType {
  SHIPPING
  COGS
  STRIPE_FEE
  REFUND
  OTHER
}

// ─── Admin Audit Log ─────────────────────────────────────────────────────────

model AdminAuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  adminId   String
  details   Json?
  createdAt DateTime @default(now())
}
