// Pepscore database schema
// Run: npx prisma db push   (to sync with Neon)
//      npx prisma generate  (to regenerate the client)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  phone     String?
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders         Order[]
  complianceLogs ComplianceAcknowledgment[]

  @@index([email])
}

enum Role {
  CUSTOMER
  ADMIN
}

// ─── Products ────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String
  size        String
  price       Float
  bulkPrice5  Float?
  bulkPrice10 Float?
  description String
  imageUrl    String
  badge       String?
  inStock     Boolean  @default(true)
  costOfGoods Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems   OrderItem[]
  invoiceItems InvoiceItem[]

  @@index([slug])
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id                    String            @id @default(cuid())
  orderNumber           String            @unique
  userId                String?
  user                  User?             @relation(fields: [userId], references: [id])
  customerEmail         String
  customerName          String
  shippingAddress       Json
  status                OrderStatus       @default(PENDING)
  fulfillmentStatus     FulfillmentStatus @default(UNFULFILLED)
  stripeSessionId       String?           @unique
  stripePaymentIntentId String?
  subtotal              Float
  shippingCost          Float             @default(0)
  stripeFee             Float             @default(0)
  tax                   Float             @default(0)
  total                 Float
  notes                 String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  items          OrderItem[]
  invoice        Invoice?
  shippingLabel  ShippingLabel?
  payments       Payment[]
  complianceLogs ComplianceAcknowledgment[]

  @@index([customerEmail])
  @@index([stripeSessionId])
  @@index([status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  FULFILLED
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  name        String
  size        String
  quantity    Int
  unitPrice   Float
  costOfGoods Float   @default(0)
  total       Float
}

// ─── Invoices ────────────────────────────────────────────────────────────────
// The invoice module stands on its own: orderId is optional so an invoice can
// represent a Stripe-driven storefront sale (linked) OR a fully manual,
// off-platform sale (unlinked) — e.g. a DM/cash sale with no Order record.
// Customer/shipping fields are duplicated onto Invoice rather than requiring
// a User/Order so a manual invoice is self-contained and never blocked on
// those records existing.

model Invoice {
  id              String  @id @default(cuid())
  invoiceNumber   String  @unique
  orderId         String? @unique
  order           Order?  @relation(fields: [orderId], references: [id])
  stripeInvoiceId String?

  // The canonical, cross-invoice Customer record this invoice belongs to
  // (nullable — every invoice created before the CRM feature has no link).
  // Fields below stay a point-in-time snapshot even when this is set, since
  // an issued invoice must remain accurate to what was true when issued.
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Set when this invoice/draft originated from a customer intake-link
  // submission — see docs/Decisions.md.
  intakeSubmittedAt DateTime?
  priority          InvoicePriority @default(NORMAL)

  // Permanent record of an admin bypassing the normal Fulfillment Gate
  // (paid in full / active payment arrangement) to ship anyway — set only
  // through lib/fulfillment/gate.ts's overrideFulfillmentEligibility(),
  // never a plain boolean, so who/when/why is never lost. See
  // docs/Decisions.md.
  fulfillmentOverrideAt   DateTime?
  fulfillmentOverrideBy   String?
  fulfillmentOverrideNote String?

  // Customer (snapshotted at invoice time, independent of User/Order)
  customerName    String
  customerCompany String?
  customerEmail   String?
  customerPhone   String?
  billingAddress  Json?
  shippingAddress Json?
  internalNotes   String?
  publicNotes     String?

  // Shipping / fulfillment
  carrier        ShippingCarrier?
  trackingNumber String?
  shippingCost   Float            @default(0)
  shipDate       DateTime?
  deliveryDate   DateTime?
  deliveredDate  DateTime?
  deliveryStatus DeliveryStatus   @default(PREPARING)

  // Carrier-agnostic tracking (see lib/tracking/) — deliveryStatus above is
  // left untouched for back-compat with existing invoices/UI; these are the
  // new normalized-status fields the tracking system actually drives.
  shippingService    String?
  trackingUrl        String?
  shippingStatus     ShippingStatus     @default(NOT_SHIPPED)
  lastTrackingUpdate DateTime?
  orderStatus        InvoiceOrderStatus @default(OPEN)

  // Denormalized snapshot of the most recent shipment notification, for
  // quick display without a join — full history lives in ShipmentNotification.
  lastNotificationType          ShippingStatus?
  lastNotificationStatus        String?
  lastNotificationSentAt        DateTime?
  lastNotificationRecipient     String?
  lastNotificationFailureReason String?

  // Denormalized snapshot of the most recent "invoice emailed to customer"
  // send (auto-sent once on first reaching ISSUED/PAID/PARTIALLY_PAID, or
  // manually resent anytime after) — same shape as the notification fields
  // above, full history lives in InvoiceActivityLog. Presence of an
  // INVOICE_ISSUED_EMAIL_SENT activity-log row is what gates the one-time
  // auto-send, not a separate boolean, so re-sending manually never confuses
  // "have we auto-sent yet."
  lastInvoiceEmailSentAt        DateTime?
  lastInvoiceEmailStatus        String?
  lastInvoiceEmailFailureReason String?

  // Financials — stored (not just derived) so history survives later price/promo edits
  subtotal      Float @default(0)
  discountTotal Float @default(0)
  total         Float @default(0)
  amountPaid    Float @default(0)
  balanceDue    Float @default(0)

  status     InvoiceStatus @default(DRAFT)
  issuedAt   DateTime      @default(now())
  paidAt     DateTime?
  archivedAt DateTime?

  // Soft-delete holding spot, distinct from archivedAt: Archive is for
  // completed invoices you keep for records; this is for "get this out of my
  // list" with a recovery window before the separate, explicit permanent-delete
  // step actually removes the row. Never set alongside a restore of the other.
  deletedAt DateTime?

  // Generated on-demand (see lib/invoice/pdf); columns reserved for when
  // persistent blob storage is added — see docs/Decisions.md
  pdfMasterUrl    String?
  pdfRecipientUrl String?

  items              InvoiceItem[]
  discounts          InvoiceDiscount[]
  payments           InvoicePayment[]
  paymentArrangement PaymentArrangement?
  // One-to-many (not the historical 1:1) — every shipment ever created for
  // this invoice, including voided/replaced ones, is preserved forever. The
  // "primary/current" shipment is always derived (see lib/shipments/primary.ts),
  // never a stored pointer. See docs/Decisions.md.
  shipments          Shipment[]
  notifications      ShipmentNotification[]
  activityLog        InvoiceActivityLog[]

  // CRM/intake back-relations — see Customer/IntakeLink/Notification models below.
  customerActivityLog CustomerActivityLog[]
  intakeLinks         IntakeLink[]
  adminNotifications  Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerEmail])
  @@index([customerName])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
}

enum InvoiceStatus {
  DRAFT
  PENDING
  APPROVED
  ISSUED
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
  VOID
}

enum ShippingCarrier {
  USPS
  UPS
  FEDEX
  DHL
  PICKUP
  HAND_DELIVERY
  COURIER
  OTHER
}

enum DeliveryStatus {
  PREPARING
  PACKED
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
  LOST
  DAMAGED
}

// Normalized, carrier-agnostic shipping status — every provider adapter in
// lib/tracking/ maps its own carrier-specific status vocabulary onto this
// fixed set, so nothing downstream (UI, PDF, email, reporting) needs to know
// which carrier or provider is actually involved.
enum ShippingStatus {
  NOT_SHIPPED
  TRACKING_ADDED
  LABEL_CREATED
  CARRIER_AWAITING_PACKAGE
  ACCEPTED_BY_CARRIER
  IN_TRANSIT
  DELAYED
  DELIVERY_EXCEPTION
  AVAILABLE_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED_TO_SENDER
  DELIVERY_ATTEMPTED
  LOST
  CANCELLED
  UNKNOWN
}

// The 4th status dimension the tracking spec calls for, kept independent of
// InvoiceStatus (payment) and ShippingStatus/deliveryStatus (fulfillment) —
// named InvoiceOrderStatus, not OrderStatus, since that name is already taken
// by the separate Stripe Order model's status enum.
enum InvoiceOrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Manual triage priority for the Awaiting Fulfillment queue — bumped inline,
// no separate assignment/triage system.
enum InvoicePriority {
  LOW
  NORMAL
  HIGH
}

// Where a tracking/activity event originated — surfaced in the invoice
// activity log per spec ("Source: Manual, Webhook, Polling, or System").
enum TrackingEventSource {
  MANUAL
  WEBHOOK
  POLLING
  SYSTEM
}

model InvoiceItem {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id])
  name         String
  description  String?
  quantity     Int      @default(1)
  unitPrice    Float
  lineDiscount Float    @default(0)
  total        Float
  sortOrder    Int      @default(0)

  @@index([invoiceId])
}

// Reusable discount templates (e.g. "FF", "Gift", "Holiday Sale") so the
// same promo can be applied across many invoices without retyping terms.
model Promotion {
  id          String        @id @default(cuid())
  name        String
  description String?
  type        PromotionType
  amount      Float
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  invoiceDiscounts InvoiceDiscount[]
}

enum PromotionType {
  FIXED
  PERCENTAGE
}

// Applied-discount snapshot. Stores its own label/type/amount independent of
// Promotion so editing or deleting a Promotion later never rewrites history
// on invoices that already used it.
model InvoiceDiscount {
  id            String        @id @default(cuid())
  invoiceId     String
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  promotionId   String?
  promotion     Promotion?    @relation(fields: [promotionId], references: [id])
  label         String
  type          PromotionType
  amount        Float
  appliedAmount Float

  @@index([invoiceId])
}

model InvoicePayment {
  id              String        @id @default(cuid())
  invoiceId       String
  invoice         Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount          Float
  method          PaymentMethod
  referenceNumber String?
  paidAt          DateTime      @default(now())
  notes           String?

  // Set when this payment satisfies a scheduled installment (see
  // PaymentArrangement below) — lets an installment's "Paid" status point
  // back to the actual payment record that satisfied it.
  installment PaymentArrangementInstallment?

  @@index([invoiceId])
}

enum PaymentMethod {
  // NA is the default for invoices that haven't received a payment yet —
  // named NA (not "N/A") since enum identifiers can't contain a slash;
  // lib/invoice/format.ts formats it back to "N/A" for display.
  NA
  CASH
  COD
  CREDIT_CARD
  DEBIT_CARD
  APPLE_PAY
  PAYPAL
  BANK_TRANSFER
  STRIPE
  SQUARE
  CASH_APP
  VENMO
  ZELLE
  ACH
  WIRE
  CHECK
  CRYPTO
  OTHER
}

// ─── Payment Arrangements (installment plans) ───────────────────────────────
// A reusable data model, not one-off form fields — deliberately separate rows
// per installment (not a JSON blob) so future features (overdue detection,
// reminders, a customer payment portal, finance reporting) can query/update
// individual installments without redesigning this layer. One arrangement
// per invoice; installment #1 is always the initial payment itself (created
// alongside the arrangement, immediately marked PAID and linked to its
// InvoicePayment), installments #2+ are the generated future schedule.

model PaymentArrangement {
  id                   String           @id @default(cuid())
  invoiceId            String           @unique
  invoice              Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  initialPaymentAmount Float
  initialPaymentDate   DateTime
  // Count of *future* installments after the initial payment (matches the
  // "Number of Remaining Payments" field) — installment #1 is the initial
  // payment, so an arrangement always has 1 + remainingPayments rows total.
  remainingPayments    Int
  frequency            PaymentFrequency

  installments PaymentArrangementInstallment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentArrangementInstallment {
  id                String             @id @default(cuid())
  arrangementId     String
  arrangement       PaymentArrangement @relation(fields: [arrangementId], references: [id], onDelete: Cascade)
  // 1-indexed; #1 is always the initial payment.
  installmentNumber Int
  dueDate           DateTime
  amount            Float
  status            InstallmentStatus  @default(PENDING)
  paidAt            DateTime?

  // Links to the InvoicePayment that actually satisfied this installment
  // (set immediately for #1, set by recordPayment() for later ones once
  // matched to the next pending installment in order).
  paymentId String?         @unique
  payment   InvoicePayment? @relation(fields: [paymentId], references: [id])

  @@unique([arrangementId, installmentNumber])
  @@index([arrangementId])
}

enum PaymentFrequency {
  WEEKLY
  BIWEEKLY
}

enum InstallmentStatus {
  PENDING
  PAID
  // Not set automatically yet (no scheduled job in this pass) — reserved
  // for the "automatic overdue detection" future enhancement; the schema
  // already supports it without another migration.
  OVERDUE
}

// ─── Payments ────────────────────────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  orderId               String
  order                 Order         @relation(fields: [orderId], references: [id])
  stripePaymentIntentId String        @unique
  amount                Float
  currency              String        @default("usd")
  status                PaymentStatus
  stripeFee             Float         @default(0)
  netAmount             Float         @default(0)
  createdAt             DateTime      @default(now())

  @@index([orderId])
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ─── Shipping ────────────────────────────────────────────────────────────────

model ShippingLabel {
  id             String   @id @default(cuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  carrier        String
  service        String
  trackingNumber String
  labelUrl       String
  shippoLabelId  String?
  cost           Float
  createdAt      DateTime @default(now())
}

// ─── Invoice Shipment Tracking ───────────────────────────────────────────────
// Carrier-agnostic tracking for invoices (distinct from ShippingLabel above,
// which is a one-time label-purchase snapshot for Stripe-driven Orders only).
// See lib/tracking/ and docs/Decisions.md for the provider-abstraction design.
//
// One row per physical shipment — an invoice can have many (multiple
// packages, a replaced/corrected tracking number, a voided label that was
// never used). None are ever deleted. The "primary" shipment shown in the
// UI/PDF is always derived (most recent non-voided row, see
// lib/shipments/primary.ts) rather than a separate pointer field, so it can
// never drift out of sync with the real collection.

model Shipment {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  carrier        ShippingCarrier
  service        String?
  trackingNumber String
  trackingUrl    String?

  normalizedStatus ShippingStatus @default(NOT_SHIPPED)
  carrierStatus    String?

  dateShipped         DateTime?
  estimatedDeliveryAt DateTime?
  deliveredAt         DateTime?

  lastCheckedAt DateTime?
  lastEventAt   DateTime?

  // Polling fallback skips shipments where this is false — cleared once a
  // shipment reaches a terminal status (delivered/returned/lost/cancelled).
  monitoringActive Boolean @default(true)

  // Which ShippingProvider adapter registered this, and its own tracking
  // object id — kept so a provider swap later can still resolve history.
  providerName       String?
  providerTrackingId String?

  // Distinguishes a real in-app Shippo label purchase from a manually-typed
  // tracking number (e.g. a hand-written label, or PICKUP/HAND_DELIVERY).
  // The fields below are only ever populated for LABEL_PURCHASE shipments.
  origin ShipmentOrigin @default(MANUAL_ENTRY)

  shippoShipmentId    String?
  shippoTransactionId String?
  postageAmount       Float?
  // What's actually attributed/charged on the invoice for this shipment —
  // may differ from postageAmount (markup, rounding), same concept as the
  // existing Invoice.shippingCost field, but per-shipment.
  shippingCost        Float?
  labelUrl            String?
  labelPdfUrl         String?

  // Package details as entered/measured for this specific purchase — kept
  // as their own fields (not folded into a form-only value) so a future
  // scale integration only needs to produce the same shape.
  weightOz Float?
  lengthIn Float?
  widthIn  Float?
  heightIn Float?

  purchasedAt DateTime?
  purchasedBy String?
  // Shippo supports refunding/voiding a label within a window — set instead
  // of deleting, so the row (and its cost) stays in the permanent record.
  voidedAt    DateTime?
  voidedBy    String?

  events        TrackingEvent[]
  notifications ShipmentNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([trackingNumber])
  @@index([monitoringActive])
}

enum ShipmentOrigin {
  MANUAL_ENTRY
  LABEL_PURCHASE
}

// One row per normalized carrier event, in provider-agnostic shape. Dedup is
// enforced at the DB level via the (shipmentId, eventHash) unique constraint —
// eventHash is the provider's own event id when available, otherwise a
// deterministic hash of (status, description, eventAt) so an out-of-order or
// re-delivered webhook/poll never creates a duplicate row.
model TrackingEvent {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  providerEventId  String?
  normalizedStatus ShippingStatus
  // Original carrier event text, preserved even though it's been mapped to a
  // normalizedStatus above — per spec, never discard the raw description.
  carrierStatus    String?
  description      String?
  location         String?
  eventAt          DateTime

  source    TrackingEventSource
  eventHash String

  createdAt DateTime @default(now())

  @@unique([shipmentId, eventHash])
  @@index([shipmentId])
}

// Full history of customer-facing shipment emails (Invoice's
// lastNotification* fields above are just a denormalized snapshot of the most
// recent row here, for quick display without a join).
model ShipmentNotification {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Which specific shipment this notification is about — required for
  // correct dedup now that an invoice can have multiple shipments (a second
  // shipment reaching DELIVERED must not be treated as "already notified"
  // just because a different, earlier shipment on the same invoice was).
  shipmentId String?
  shipment   Shipment? @relation(fields: [shipmentId], references: [id])

  notificationType ShippingStatus
  recipient        String
  status           String
  failureReason    String?

  sentAt DateTime @default(now())

  @@index([invoiceId])
  @@index([invoiceId, notificationType])
  @@index([shipmentId, notificationType])
}

// Dedicated activity log for shipment/tracking events on an invoice —
// deliberately separate from AdminAuditLog (which is shaped for admin-
// initiated CRUD actions like Archive/Trash and always requires an adminId).
// This log covers automated sources too (webhook/polling/system), so
// userId is optional.
model InvoiceActivityLog {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  eventType      String
  previousValue  String?
  newValue       String?
  carrier        ShippingCarrier?
  trackingNumber String?
  source         TrackingEventSource
  userId         String?

  // Which shipment this entry refers to, when relevant — plain id, no FK
  // relation (informational only, avoids yet another back-relation array on
  // Shipment for what's just a display detail).
  shipmentId String?

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

// ─── Customers (CRM) ─────────────────────────────────────────────────────────
// Customer is the primary record intake links, notifications, and the
// timeline all hang off of — see docs/Decisions.md. Invoice keeps its own
// snapshotted name/company/email/phone/addresses (unchanged, above) since an
// issued invoice must stay accurate to what was true when it was issued even
// if the customer's info changes later; Customer is the current, canonical,
// cross-invoice record.

model Customer {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  company   String?
  email     String?
  phone     String?

  billingAddress  Json?
  shippingAddress Json?

  preferredContactMethod PreferredContactMethod?
  preferredPaymentMethod PaymentMethod?
  notes                  String?

  // Recomputed at the same touchpoints that write CustomerActivityLog below
  // (mirrors the existing computeOrderStatus pattern) — see
  // lib/customers.ts's computeCustomerStatus(). Never derived at read time,
  // so filtering/sorting by status is a plain indexed column.
  status CustomerStatus @default(LEAD)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices      Invoice[]
  intakeLinks   IntakeLink[]
  activityLog   CustomerActivityLog[]
  notifications Notification[]

  @@index([email])
  @@index([phone])
  @@index([status])
}

enum PreferredContactMethod {
  SMS
  EMAIL
  PHONE
}

enum CustomerStatus {
  LEAD
  INTAKE_SENT
  INTAKE_COMPLETED
  AWAITING_FULFILLMENT
  INVOICE_ISSUED
  AWAITING_PAYMENT
  PARTIALLY_PAID
  // A payment plan is on record with at least one installment still owed —
  // distinct from (and takes priority over) plain AWAITING_PAYMENT/
  // PARTIALLY_PAID, since it means fulfillment is already unlocked (see
  // lib/fulfillment/gate.ts) even though the invoice isn't paid off yet.
  PAYMENT_ARRANGEMENT
  PAID
  // Fulfillment Gate has passed (paid in full, or a manual override) but no
  // shipment has been created yet.
  ELIGIBLE_FOR_FULFILLMENT
  // A label has been purchased/registered but the carrier hasn't scanned it
  // yet — split out from PREPARING_SHIPMENT for more specific visibility.
  LABEL_CREATED
  PREPARING_SHIPMENT
  SHIPPED
  DELIVERED
  ARCHIVED
}

// Permanent, append-only history for a customer — both lifecycle events
// (intake generated/viewed/submitted, invoice issued, payment received,
// shipment created/delivered, ...) and every outbound communication (intake/
// invoice/shipment emails, future SMS/calls). One unified table rather than
// two, since "what happened" and "what we sent" are the same timeline from
// the customer's point of view. Mirrors InvoiceActivityLog's shape (above)
// so it renders the same way in the UI. Nothing here is ever deleted.
model CustomerActivityLog {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invoiceId  String?
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])

  eventType     String
  previousValue String?
  newValue      String?
  source        TrackingEventSource
  userId        String?

  // Which shipment this entry refers to, when relevant — plain id, same
  // rationale as InvoiceActivityLog.shipmentId above.
  shipmentId String?

  createdAt DateTime @default(now())

  @@index([customerId, createdAt])
}

// ─── Customer Intake Links ───────────────────────────────────────────────────
// Public, token-authenticated links a customer fills in themselves — see
// docs/Decisions.md. The token (not this row's id) is the entire security
// boundary, same pattern as the Shippo webhook's ?token= and CRON_SECRET.
// Multi-use until expiry/invalidation, not single-use, so a customer who
// doesn't finish — or an admin re-requesting info on an open draft — can
// reuse the same link.

model IntakeLink {
  id         String    @id @default(cuid())
  token      String    @unique
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  invoiceId  String?
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id])

  createdBy String

  expiresAt     DateTime
  // Set on the first GET — feeds the "Intake Viewed" timeline event and
  // intake analytics (completion rate, avg completion time).
  viewedAt      DateTime?
  invalidatedAt DateTime?
  submittedAt   DateTime?

  // Rejected past a small threshold — the primary spam defense is the
  // unguessable token itself; this just caps brute-force guessing attempts.
  submissionAttempts Int @default(0)

  createdAt DateTime @default(now())

  @@index([customerId])
  @@index([invoiceId])
}

// ─── Admin Notifications ─────────────────────────────────────────────────────
// Pluggable NotificationChannel abstraction (lib/notifications/) — dashboard
// delivery is this row itself, email/SMS fan out to enabled
// AdminNotificationRecipient rows. See docs/Decisions.md.

model Notification {
  id         String    @id @default(cuid())
  type       String
  invoiceId  String?
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id])
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  isNewCustomer Boolean

  // Set when the widened duplicate-detection check (name/company/address
  // similarity, short of an exact email/phone match) flags a possible match
  // for admin review — never auto-merged, just surfaced. Holds the id of the
  // existing Customer it might duplicate.
  possibleDuplicateOf String?

  read      Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([read, createdAt])
}

// A list, not a singleton — supports multiple administrators from day one.
// Configured entirely through Settings -> Admin Notifications; phone/email
// values are data entered through that form, never literals in code.
model AdminNotificationRecipient {
  id           String  @id @default(cuid())
  name         String?
  email        String?
  phone        String?
  emailEnabled Boolean @default(true)
  smsEnabled   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Invoice Numbering ───────────────────────────────────────────────────────
// Replaces the previous count()-derived numbering in lib/invoice/numbering.ts,
// which silently reused a number if the invoice holding it was ever
// permanently deleted (the count simply dropped). One row per year,
// incremented atomically so concurrent creates can't race, and a delete can
// never free up a number for reuse.
model InvoiceNumberCounter {
  year         Int @id
  lastSequence Int @default(0)
}

// ─── Compliance ──────────────────────────────────────────────────────────────

model ComplianceAcknowledgment {
  id        String   @id @default(cuid())
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  sessionId String?
  ipAddress String?
  userAgent String?
  // Full RUO text the customer agreed to
  ruoText   String
  agreedAt  DateTime @default(now())
}

// ─── Accounting ──────────────────────────────────────────────────────────────

model Expense {
  id          String      @id @default(cuid())
  type        ExpenseType
  amount      Float
  description String?
  orderId     String?
  date        DateTime    @default(now())
  createdAt   DateTime    @default(now())

  @@index([type])
  @@index([date])
}

enum ExpenseType {
  SHIPPING
  COGS
  STRIPE_FEE
  REFUND
  OTHER
}

// ─── Admin Audit Log ─────────────────────────────────────────────────────────

model AdminAuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  adminId   String
  details   Json?
  createdAt DateTime @default(now())
}

// ─── Invoice Settings ────────────────────────────────────────────────────────
// Single-row table (always fetched/upserted by the fixed id below) rather than
// a generic key-value settings table — there's exactly one invoice-related
// setting today, and a dedicated typed column beats an untyped JSON blob for
// the one value that exists.
model InvoiceSettings {
  id String @id @default("singleton")

  // Days after paidAt before a PAID invoice auto-archives; null = never
  // auto-archive. See docs/Decisions.md #21.
  archiveAfterDays Int? @default(30)

  // Per-ShippingStatus on/off toggle for customer notification emails, e.g.
  // {"DELAYED": false}. A status missing from this map is treated as
  // enabled — so the default (empty/null) is "everything on" without
  // needing to seed every enum value. See lib/tracking/notifications.ts.
  trackingNotificationsEnabled Json?

  // Auto-email the Client Invoice PDF to customerEmail the first time an
  // invoice reaches ISSUED/PAID/PARTIALLY_PAID. Off doesn't touch the manual
  // "Email Invoice to Customer" button — that always works regardless.
  autoEmailInvoiceOnIssue Boolean @default(true)

  // Default lifespan of a generated customer intake link before it stops
  // accepting submissions (still regenerable). See docs/Decisions.md.
  defaultIntakeLinkExpiryHours Int @default(48)

  updatedAt DateTime @updatedAt
}
