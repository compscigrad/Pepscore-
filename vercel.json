{
  "framework": "nextjs",
  "headers": [
    {
      "source": "/api/webhooks/stripe",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://hooks.stripe.com" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/archive-invoices",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/poll-tracking",
      "schedule": "0 */4 * * *"
    }
  ]
}
